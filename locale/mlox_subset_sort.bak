#: mlox_subset_sort_gui.py:274
msgid "Rule files (priority = order below, last = highest -- drag rows to reorder)"
msgstr ""

#: mlox_subset_sort_gui.py:296
msgid "mlox rule files (mlox_base.txt, mlox_user.txt, ...), applied in this order.\nLater files can override/extend earlier ones -- put mlox_base.txt first and your own mlox_user.txt last. Drag rows to reorder, or use the buttons."
msgstr ""

#: mlox_subset_sort_gui.py:312
msgid "Add File(s)..."
msgstr ""

#: mlox_subset_sort_gui.py:314
msgid "Browse for one or more mlox rule .txt files to add to the list."
msgstr ""

#: mlox_subset_sort_gui.py:315
msgid "Remove Selected"
msgstr ""

#: mlox_subset_sort_gui.py:319
msgid "Remove the selected rule file from the list (doesn't delete anything on disk)."
msgstr ""

#: mlox_subset_sort_gui.py:321
#: mlox_subset_sort_gui.py:535
msgid "Move Up"
msgstr ""

#: mlox_subset_sort_gui.py:323
msgid "Move the selected rule file earlier (lower priority)."
msgstr ""

#: mlox_subset_sort_gui.py:324
#: mlox_subset_sort_gui.py:544
msgid "Move Down"
msgstr ""

#: mlox_subset_sort_gui.py:326
msgid "Move the selected rule file later (higher priority)."
msgstr ""

#: mlox_subset_sort_gui.py:331
msgid "New Rule..."
msgstr ""

#: mlox_subset_sort_gui.py:335
msgid "Write your own mlox [Order]/[NearStart]/[NearEnd] rule without knowing the syntax: pick plugins (or grab the selected rows from the plugin panel), preview the rule, and append it to a personal rules file that loads LAST so it wins conflicts. This is how rules for modern mods get made -- consider contributing good ones upstream."
msgstr ""

#: mlox_subset_sort_gui.py:343
msgid "Update Rules..."
msgstr ""

#: mlox_subset_sort_gui.py:347
msgid "Download the CURRENT mlox_base.txt / mlox_user.txt from the actively maintained rules repo (github.com/%(repo)s -- the same source plox uses, and mlox 1.1+ auto-updates from) over the matching files in this list. The old files are kept as timestamped .bak copies. Files with other names (your personal rules) are never touched. Source URL configurable via Sources..."
msgstr ""

#: mlox_subset_sort_gui.py:358
msgid "Sources..."
msgstr ""

#: mlox_subset_sort_gui.py:362
msgid "Configure WHERE 'Update Rules...' and the plugin-order.yml 'Update...' button download from -- point them at a fork or mirror if upstream moves. Blank fields use the built-in defaults."
msgstr ""

#: mlox_subset_sort_gui.py:376
msgid "(install tkinterdnd2 to drag files in from your file manager)"
msgstr ""

#: mlox_subset_sort_gui.py:385
#: mlox_subset_sort_gui.py:393
#: mlox_subset_sort_gui.py:410
msgid "Update rules"
msgstr ""

#: mlox_subset_sort_gui.py:385
msgid "Add mlox_base.txt and/or mlox_user.txt to the list first."
msgstr ""

#: mlox_subset_sort_gui.py:394
msgid "Download the current rules from github.com/%(repo)s over these files?\n\n%(age)s\n\nTimestamped .bak copies of the old files are kept."
msgstr ""

#: mlox_subset_sort_gui.py:539
msgid "Move the selected row(s) one position earlier. Works with a multi-selection; you can also drag a contiguous block up with the mouse."
msgstr ""

#: mlox_subset_sort_gui.py:548
msgid "Move the selected row(s) one position later. Works with a multi-selection; you can also drag a contiguous block down with the mouse."
msgstr ""

#: mlox_subset_sort_gui.py:553
msgid "Disable / Enable"
msgstr ""

#: mlox_subset_sort_gui.py:557
msgid "Opt the selected row in or out of the load order. Disabled rows are dimmed and marked, and are left out of Export: a custom item is simply not inserted, and an item already in your openmw.cfg gets a removeContent/removeData entry in the emitted TOML so it's durably removed. Double-click a row to toggle it too."
msgstr ""

#: mlox_subset_sort_gui.py:568
msgid "Discard any manual dragging and restore the order from the last Sort (your disable/enable choices are kept)."
msgstr ""

#: mlox_subset_sort_gui.py:727
msgid "Plugin load order -- drag to override mlox (red = touched by this sort, purple = master problem)"
msgstr ""

#: mlox_subset_sort_gui.py:754
msgid "Data path order -- drag to adjust (highlighted = your custom paths)"
msgstr ""

#: mlox_subset_sort_gui.py:1140
msgid "Drag & drop is disabled (tkinterdnd2 not installed) -- use the Browse buttons below."
msgstr ""

#: mlox_subset_sort_gui.py:1165
msgid "Required. The openmw.cfg to read the current content= and data= order from, and (if 'Write openmw.cfg directly' is checked) to patch."
msgstr ""

#: mlox_subset_sort_gui.py:1176
msgid "A momw-configurator/umo customizations TOML to pull the plugin/data-path subset from automatically. Optional if you provide a subset file instead -- provide both and they're combined."
msgstr ""

#: mlox_subset_sort_gui.py:1188
msgid "A plain text file (one plugin filename or data folder path per line, '#' comments allowed) or a minimal TOML with subset=[...]/data=[...]. Combined with --emit-toml, this alone is enough to generate a brand new customizations.toml with no existing one required."
msgstr ""

#: mlox_subset_sort_gui.py:1211
msgid "Where to write a corrected customizations.toml (sorted insert blocks, re-anchored). Disabled when 'write directly back' below is checked."
msgstr ""

#: mlox_subset_sort_gui.py:1222
msgid "list name (optional):"
msgstr ""

#: mlox_subset_sort_gui.py:1243
msgid "MOMW's plugin-order.yml (source of truth for which plugins belong to which curated list). With the list name above set, curated plugins for that list are excluded from the sort (never reordered) so only your custom additions are touched, and read-only warnings are emitted: redundant, orphan, needs-cleaning, and a base-order drift check. PyYAML used if installed, else a built-in parser."
msgstr ""

#: mlox_subset_sort_gui.py:1264
msgid "Write directly back to customizations.toml (overwrite in place; a .bak-<timestamp> copy is made first unless backups are disabled below)"
msgstr ""

#: mlox_subset_sort_gui.py:1274
msgid "Instead of writing to a separate file above, overwrite the customizations.toml given above in place. A timestamped backup is made first (unless disabled), and you'll get a confirmation prompt before it actually happens."
msgstr ""

#: mlox_subset_sort_gui.py:1290
msgid "Options"
msgstr ""

#: mlox_subset_sort_gui.py:1305
msgid "Dry run (preview only, don't write files)"
msgstr ""

#: mlox_subset_sort_gui.py:1310
msgid "When checked, Export shows exactly what it would write without touching any files. Uncheck when you're ready to actually save."
msgstr ""

#: mlox_subset_sort_gui.py:1317
msgid "Write openmw.cfg directly"
msgstr ""

#: mlox_subset_sort_gui.py:1322
msgid "Patch the content=/data= lines in openmw.cfg in place on Export. A .bak-<timestamp> copy is made first unless backups are disabled."
msgstr ""

#: mlox_subset_sort_gui.py:1329
msgid "Sort data= paths too"
msgstr ""

#: mlox_subset_sort_gui.py:1334
msgid "mlox has no concept of data= folder order -- this positions new data= paths using an explicit after/before anchor if you wrote one, or by scanning the folder for plugins and anchoring next to their neighbor in the sorted content= order. Off by default so a plugin-only run can't surprise-reorder data= too. Also required for the data path order panel to populate."
msgstr ""

#: mlox_subset_sort_gui.py:1344
msgid "Skip .bak backup of openmw.cfg"
msgstr ""

#: mlox_subset_sort_gui.py:1349
msgid "Skip making a timestamped backup before overwriting openmw.cfg and/or an in-place customizations.toml. Not recommended."
msgstr ""

#: mlox_subset_sort_gui.py:1357
msgid "Skip mlox Conflict/Requires/Note warnings"
msgstr ""

#: mlox_subset_sort_gui.py:1363
msgid "Skip evaluating [Conflict]/[Requires]/[Note] rules against the sorted plugin list. This is purely informational and read-only either way -- it never changes the computed order or what gets written, only whether warnings get printed."
msgstr ""

#: mlox_subset_sort_gui.py:1372
msgid "Create subset text document (on Scan)"
msgstr ""

#: mlox_subset_sort_gui.py:1377
msgid "Exclude from conflict / cell scans:"
msgstr ""

#: mlox_subset_sort_gui.py:1391
msgid "Keep tes3conv JSON dump"
msgstr ""

#: mlox_subset_sort_gui.py:1398
msgid "tes3conv conversions are written to disk (not held in RAM) and read per-plugin, so big load orders don't blow up memory. They always go to a 'tes3conv_json' folder next to the app and are reused within a run -- so Check Conflicts then Cell Map won't re-run tes3conv (a plugin is only re-converted if it changed). This box just decides what happens on exit: checked = keep that folder (reused next launch too); unchecked = delete it when you close the app."
msgstr ""

#: mlox_subset_sort_gui.py:1409
msgid "Controls what 'Scan...' does with its result. Checked: write the scanned list to a .txt subset file you choose, and load it (the file stays on disk for reuse). Unchecked: keep the scanned list in memory just for this session and feed it straight to the sort -- nothing is written to disk."
msgstr ""

#: mlox_subset_sort_gui.py:1551
msgid "Log"
msgstr ""

#: mlox_subset_sort_gui.py:1573
msgid "Full output from the last Sort and/or Export. Colour key: green = a plugin/path this sort inserted or moved, orange = a heads-up (mlox warning, or a rule your curated cfg order overrode), blue = a section header, bright red = an error worth checking. Plain text = frozen base rows left untouched. Colors follow the syntax highlighting theme picked below."
msgstr ""


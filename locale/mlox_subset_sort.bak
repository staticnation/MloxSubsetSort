#: mlox_subset/gui/conflicts.py:902
msgid "Show graph..."
msgstr ""

#: mlox_subset/gui/conflicts.py:908
msgid "Draw the path grid as a navigation graph, with the edges this plugin added in green and the ones it removed in red.\n\nA mod that only REMOVES edges has probably rebuilt its path grid by accident -- that breaks NPC movement and nothing else reports it."
msgstr ""

#: mlox_subset/gui/conflicts.py:920
msgid "Show difference..."
msgstr ""

#: mlox_subset/gui/conflicts.py:926
msgid "Decode both versions to absolute heights and subtract them: red where the winner raised the ground, blue where it lowered it.\n\nComparing the raw values above is misleading. Heights are stored as cumulative deltas, so moving ONE vertex changes every byte after it and two nearly-identical cells look completely different."
msgstr ""

#: mlox_subset/gui/conflicts.py:938
msgid "Show in 3D..."
msgstr ""

#: mlox_subset/gui/conflicts.py:944
msgid "Draw the cell's terrain as a surface you can rotate, with each plugin's version switchable in place. Drag to turn it.\n\nShading follows slope rather than height, which reads as terrain."
msgstr ""

